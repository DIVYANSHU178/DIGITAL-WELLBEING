<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.wellbeing.ui.MainController"
            styleClass="app-shell">
    <top>
        <VBox styleClass="top-shell">
            <padding>
                <Insets top="24" right="28" bottom="18" left="28" />
            </padding>
            <HBox alignment="CENTER_LEFT" spacing="18">
                <VBox spacing="6">
                    <Label text="Desktop Digital Wellbeing" styleClass="app-title" />
                    <Label text="Track focus, screen time, and weekly habits in one place." styleClass="app-subtitle" />
                </VBox>
                <Region HBox.hgrow="ALWAYS" />
                <HBox styleClass="nav-bar" spacing="10">
                    <ToggleButton fx:id="dashboardButton" text="Dashboard" styleClass="nav-button" onAction="#showDashboard" />
                    <ToggleButton fx:id="appDetailsButton" text="App Details" styleClass="nav-button" onAction="#showAppDetails" />
                    <ToggleButton fx:id="weeklyReportButton" text="Weekly Report" styleClass="nav-button" onAction="#showWeeklyReport" />
                    <ToggleButton fx:id="settingsButton" text="Settings" styleClass="nav-button" onAction="#showSettings" />
                </HBox>
            </HBox>
        </VBox>
    </top>
    <center>
        <StackPane fx:id="contentContainer" styleClass="content-host">
            <BorderPane.margin>
                <Insets top="0" right="28" bottom="28" left="28" />
            </BorderPane.margin>
        </StackPane>
    </center>
</BorderPane>
